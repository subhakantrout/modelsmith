# ModelSmith Configuration
# Copy this to .env and adjust as needed.

# Backend
HOST=0.0.0.0
PORT=8765

# HuggingFace Hub token (optional, for gated models)
HF_TOKEN=

# Model storage directory (default: ./models)
MODEL_DIR=models

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Frontend dev server port (for Vite proxy)
VITE_PORT=5173
